{
  "compilerOptions": {
    "module": "Node16", // CommonJS yerine Node16
    "moduleResolution": "Node16", // uyumlu hale geldi
    "target": "ES2020",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./src",
    "paths": {
      "services/*": ["services/*"],
      "controllers/*": ["controllers/*"],
      "utils/*": ["utils/*"],
      "validation/*": ["validation/*"],
      "routes/*": ["routes/*"],
      "types/*": ["types/*"],
      "db/*": ["db/*"],
      "middlewares/*": ["middlewares/*"],
      "constants/*": ["constants/*"]
    }
  },
  "include": ["src"]
}
