{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "services/*": ["./src/services/*"],
      "controllers/*": ["./src/controllers/*"],
      "utils/*": ["./src/utils/*"],
      "validation/*": ["./src/validation/*"],
      "routes/*": ["./src/routes/*"],
      "types/*": ["./src/types/*"],
      "db/*": ["./src/db/*"],
      "middlewares/*": ["./src/middlewares/*"],
      "constants/*": ["./src/constants/*"]
    }
  },
  "include": ["src"]
}
